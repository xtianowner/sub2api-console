# ── Sub2API Console 配置示例 ──  cp .env.example .env 后按需填写（.env 不会入库）

# 对外 Web 端口（宿主机）。容器内固定 21013，勿改 PORT。
CONSOLE_PORT=21013

# 本平台所在 docker 网络（需与 sub2api 的 postgres 同网，才能用容器名互通）。
# 查法：docker network ls | grep sub2api  （官方 compose 默认 sub2api_sub2api-net）
SUB2API_NETWORK=sub2api_sub2api-net

# ── 本机站点(kind=local)的 sub2api postgres 连接 ──
# 观测 + 本机 token 回源 用「只读」用户；改 role(UPDATE users) 用「可写」用户。
# 远程站点不用这两个(走 ssh 提权通道)。host 用容器名(同 docker 网)或可达地址。
DATABASE_URL=postgres://observer_readonly:CHANGE_ME@sub2api-postgres:5432/sub2api?sslmode=disable
# 可写用户(改 role 用)；不填则回落 DATABASE_URL(只读则改 role 会失败)。
ADMIN_DATABASE_URL=postgres://sub2api:CHANGE_ME@sub2api-postgres:5432/sub2api?sslmode=disable

# 管理员登录密码（首启播种为哈希存库；之后可在设置里改密）。务必改掉。
CONSOLE_ADMIN_PASSWORD=CHANGE_ME

# 凭据主密钥(加密站点 admin_key 等)；留空首启自动生成并存库，请随 SQLite 卷一起备份。
# CONSOLE_MASTER_KEY=

# 工具侧 SQLite 路径(派生元数据/密码哈希/master_key)；对应 compose 的 ./data 卷。
CONSOLE_DB_PATH=/data/console.db

# 探活用模型
CONSOLE_PROBE_MODEL=gpt-5.5

# oauth 账号探活出口代理(prober 经它访问 chatgpt.com)。
# 若本机直连 openai 通畅可留空；否则填能到 openai 的 socks5/http 代理(如自建 ssh -D 隧道)。
# 例：CONSOLE_PROBE_PROXY=socks5h://<host>:<port>
CONSOLE_PROBE_PROXY=
